# Project Name (used for Docker container and volume naming)
# Change this for different projects to use separate databases
PROJECT_NAME=njbe-web-api

# Database Configuration (for local development with Docker)
# DB_DATABASE, DB_USER, DB_PASSWORD are defined in docker-compose.yml
# Uncomment and override them here only if you need different values
# DB_DATABASE=njbe-web-api
# DB_USER=njbe_web_api_user
# DB_PASSWORD=local_password
DB_HOST=localhost
DB_PORT=5432

# Nuxt Database URL (PostgreSQL connection string)
# Format: postgres://user:password@host:port/database
NUXT_DATABASE_URL=postgres://njbe_web_api_user:local_password@localhost:5432/njbe-web-api

# Nuxt Session Password (required for nuxt-auth-utils)
# Generate with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=change-this-to-a-secure-random-string-min-32-chars

# Default admin credentials
NUXT_ADMIN_USERNAME=admin
NUXT_ADMIN_PASSWORD=change-me
NUXT_ADMIN_EMAIL=admin@example.com
